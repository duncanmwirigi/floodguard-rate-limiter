# Copy to .env and source before running: set -a && source .env && set +a
# Or use with Docker Compose / Kubernetes envFrom.

# Server
LISTEN_ADDR=:8080

# Redis
REDIS_ADDR=localhost:6379
REDIS_KEY_PREFIX=floodguard
REDIS_PING_TIMEOUT=3s

# Rate limits (sliding window per IP / per account)
IP_RATE_LIMIT=30
IP_RATE_WINDOW=1m
ACCOUNT_RATE_LIMIT=10
ACCOUNT_RATE_WINDOW=1m

# Idempotency
IDEMPOTENCY_TTL=24h

# Velocity rules
VELOCITY_WITHDRAW_MAX=3
VELOCITY_WINDOW=1m
VELOCITY_MIN_INTERVAL=200ms

# Distributed lock
LOCK_TTL=30s

# Middleware toggles
BLOCK_ON_VELOCITY=false
REQUIRE_IDEMPOTENCY_KEY=true
REQUIRE_LOCK=true

# Platform anomaly detection
ANOMALY_SPIKE_MULTIPLIER=5
ANOMALY_LOOKBACK_MINUTES=60

# Challenge / CAPTCHA layer
CHALLENGE_NEW_ACCOUNT_MAX_AGE=24h

# Step-up auth
STEPUP_TOKEN_TTL=10m

# Device trust store: memory | redis
DEVICE_TRUST_STORE=memory

# Notifications on sensitive actions from new devices
NOTIFY_ENABLED=true

# Demo seed balances (account_id=KES cents) — see example/testdata/accounts.json
DEMO_ACCOUNT_BALANCES=acct-1001=50000,acct-1002=10000,acct-empty=100
